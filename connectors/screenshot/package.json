{
  "name": "screenshot",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "lint": "eslint --max-warnings 0 src/*.js",
    "format": "prettier --write src/",
    "format:ci": "prettier --check src/"
  },
  "author": "Tien Duc Nguyen",
  "license": "EUPL-1.2",
  "description": "Small service that extracts a sprite in SVG format from Scratch project json",
  "bin": {
    "screenshot": "src/index.js"
  },
  "dependencies": {
    "express": "5.1.0",
    "jsdom": "27.0.1",
    "scratch-audio": "2.0.241",
    "scratch-blocks": "1.1.225",
    "scratch-vm": "5.0.300"
  },
  "bundleDependencies": [
    "express",
    "jsdom",
    "scratch-audio",
    "scratch-blocks",
    "scratch-vm"
  ],
  "devDependencies": {
    "@eslint/js": "9.38.0",
    "eslint": "9.38.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.4.0",
    "prettier": "3.6.2"
  }
}
